<UserControl x:Class="ZitiDesktopEdge.GetStarted"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:ZitiDesktopEdge.ViewModels"
             xmlns:local="clr-namespace:ZitiDesktopEdge"
             mc:Ignorable="d"
             MaxWidth="{StaticResource MaxWindowWidth}"
             Visibility="{Binding Visibility}"
             d:DataContext="{d:DesignInstance Type=vm:GetStartedViewModel, IsDesignTimeCreatable=True}"
             d:DesignHeight="640"
             d:DesignWidth="480">
    <UserControl.Resources>
        <FontFamily x:Key="BodyFont">pack://application:,,,/Assets/Fonts/#Open Sans</FontFamily>
        <FontFamily x:Key="HeadingFont">pack://application:,,,/Assets/Fonts/#Russo One</FontFamily>

        <SolidColorBrush x:Key="GetStartedHeading" Color="#D6DEE8"/>
        <SolidColorBrush x:Key="GetStartedBody" Color="#A6AEBD"/>
        <SolidColorBrush x:Key="GetStartedLink" Color="#9FBCD9"/>
        <SolidColorBrush x:Key="GetStartedLinkHover" Color="#C4D6EA"/>

        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource HeadingFont}"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Foreground" Value="{StaticResource GetStartedHeading}"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
        <Style x:Key="SectionBody" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource BodyFont}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="{StaticResource GetStartedBody}"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
        <Style x:Key="LinkParagraph" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource BodyFont}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Margin" Value="0,0,0,14"/>
        </Style>
        <Style x:Key="GetStartedHyperlink" TargetType="Hyperlink">
            <Setter Property="Foreground" Value="{StaticResource GetStartedLink}"/>
            <Setter Property="TextDecorations" Value="Underline"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="{StaticResource GetStartedLinkHover}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid x:Name="GetStartedArea" Margin="0,0,0,0">
        <!-- Drop shadow border matching MFAScreen / other modals -->
        <Border Margin="10,10,10,10" BorderBrush="Black" BorderThickness="8" CornerRadius="10">
            <Border.Effect>
                <DropShadowEffect BlurRadius="20" Direction="1" RenderingBias="Quality" ShadowDepth="1" Opacity="1"/>
            </Border.Effect>
        </Border>

        <!-- Dark theme backdrop -->
        <Rectangle Margin="10,10,10,10" RadiusX="12" RadiusY="12" ClipToBounds="True">
            <Rectangle.Fill>
                <SolidColorBrush Color="{StaticResource DarkBackground}" Opacity="0.97"/>
            </Rectangle.Fill>
            <Rectangle.Stroke>
                <SolidColorBrush Color="White" Opacity="0.4"/>
            </Rectangle.Stroke>
        </Rectangle>

        <Grid Margin="24,28,24,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Logo on a white card so the brand reads against the dark backdrop -->
            <Border Grid.Row="0"
                    Background="White"
                    CornerRadius="8"
                    Padding="4,0"
                    Margin="0,0,0,18"
                    HorizontalAlignment="Stretch"
                       Cursor="ScrollAll"
                       ToolTip="Drag to detach/move, right click to reattach"
                       MouseDown="Logo_MouseDown"
                       MouseUp="Logo_MouseUp">
                <Image Source="/Assets/Images/netfoundry-logo.png"
                       MaxHeight="70"
                       Stretch="Uniform"
                       HorizontalAlignment="Center"
                       RenderOptions.BitmapScalingMode="Fant"/>
            </Border>

            <TextBlock Grid.Row="1"
                       Text="Welcome to Ziti Desktop Edge"
                       FontFamily="{StaticResource HeadingFont}"
                       FontSize="18"
                       Foreground="{StaticResource GetStartedHeading}"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,12"/>

            <Rectangle Grid.Row="2"
                       Height="1"
                       Fill="White"
                       Opacity="0.18"
                       HorizontalAlignment="Stretch"
                       Margin="0,0,0,16"/>

            <StackPanel Grid.Row="3" Orientation="Vertical">
                <TextBlock Style="{StaticResource SectionHeader}" Text="Deploy a Network"/>
                <TextBlock Style="{StaticResource SectionBody}"
                           Text="New to OpenZiti? Get started by deploying your own zero trust network overlay."/>
                <TextBlock Style="{StaticResource LinkParagraph}">
                    <Hyperlink Style="{StaticResource GetStartedHyperlink}"
                               NavigateUri="https://netfoundry.io/docs/openziti/#deploy_an_overlay"
                               RequestNavigate="Hyperlink_RequestNavigate">
                        <Run Text="Learn how to deploy a network"/>
                    </Hyperlink>
                </TextBlock>

                <TextBlock Style="{StaticResource SectionHeader}" Text="Already have a network?"/>
                <TextBlock Style="{StaticResource SectionBody}">
                    <Run Text="If a network administrator has already sent you an enrollment file or URL join that network now: "/>
                    <Hyperlink Style="{StaticResource GetStartedHyperlink}" Click="AddByJwt_Click">
                        <Run Text="Add by JWT"/>
                    </Hyperlink>
                    <Run Text=" or "/>
                    <Hyperlink Style="{StaticResource GetStartedHyperlink}" Click="AddByUrl_Click">
                        <Run Text="Add by URL"/>
                    </Hyperlink>
                    <Run Text="."/>
                </TextBlock>
                <Grid Margin="0,4,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Image Grid.Column="0"
                           Source="/Assets/Images/identity.png"
                           Width="30"
                           Height="30"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0"
                           RenderOptions.BitmapScalingMode="Fant"/>
                    <TextBlock Grid.Column="1"
                               Style="{StaticResource SectionBody}"
                               Margin="0"
                               Text="You can always add more later via the &quot;Add Identity&quot; button at the top right of the main screen."/>
                </Grid>

                <TextBlock Style="{StaticResource SectionHeader}" Text="Need Help?"/>
                <TextBlock Style="{StaticResource SectionBody}" Text="Community support for open source users:"/>
                <TextBlock Style="{StaticResource LinkParagraph}" Margin="0,0,0,8">
                    <Hyperlink Style="{StaticResource GetStartedHyperlink}"
                               NavigateUri="https://openziti.discourse.group/"
                               RequestNavigate="Hyperlink_RequestNavigate">
                        <Run Text="OpenZiti Discourse Community"/>
                    </Hyperlink>
                </TextBlock>
                <TextBlock Style="{StaticResource SectionBody}" Text="Commercial support for NetFoundry customers:"/>
                <TextBlock Style="{StaticResource LinkParagraph}">
                    <Hyperlink Style="{StaticResource GetStartedHyperlink}"
                               NavigateUri="https://netfoundry.io/support/"
                               RequestNavigate="Hyperlink_RequestNavigate">
                        <Run Text="NetFoundry Support"/>
                    </Hyperlink>
                </TextBlock>
            </StackPanel>

            <local:StyledButton Grid.Row="4"
                                x:Name="CloseButton"
                                Label="Close"
                                Width="160"
                                HorizontalAlignment="Center"
                                Margin="0,12,0,0"
                                Command="{Binding CloseCommand}"/>
        </Grid>

        <Image Source="/Assets/Images/close.png"
               VerticalAlignment="Top"
               HorizontalAlignment="Right"
               Margin="0,30,30,0"
               Width="12"
               Height="12"
               Cursor="Hand"
               MouseUp="CloseImage_MouseUp"/>
    </Grid>
</UserControl>
